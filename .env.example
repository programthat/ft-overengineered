# Copy to .env and fill in what you need. Everything here is optional — with an empty .env the game runs
# read-only against the production database, which is what you want almost all of the time.

# --- Publishing -------------------------------------------------------------------------------------------
# `npm run publish` reads it
PUBLISH_KEY=

# --- Database (Studio only) -------------------------------------------------------------------------------
# Write token for the external save database.
#
# ⚠  This is a LIVE WRITE PATH TO PRODUCTION. There is no staging database, and it is not just the Save
#    button: a Studio session autosaves every 5 minutes and snapshots your plot when you leave, so a token
#    here overwrites your real slots without you pressing anything.
#
#    Leave it empty unless you are specifically testing writes, and clear it when you are done. Empty means
#    read-only: loads work, saves stay in the datastore and never leave your session.
WRITETOKEN=

# Where Studio looks for the database.
# Set this to the relay (below) if your connection cannot pull real saves. 
# Leave it empty for production build.
DB_BASEURL=

# --- Relay (scripts/dbrelay.js) ---------------------------------------------------------------------------
# Only `npm run dbrelay` reads these. You need it only if loading a slot in Studio fails with the below
# HttpError: NetFail or Timedout —> see the README.
# The proxy to tunnel through. Empty = relay disabled
RELAY_PROXY=

# Upstream and local port
# https://github.com/anywaymachines/overengineered-database-selfhost
RELAY_TARGET=http://localhost
RELAY_PORT=1367
