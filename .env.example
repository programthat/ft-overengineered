# Copy to .env and fill in what you need. Everything here is optional — with an empty .env the game runs
# read-only against the production database, which is what you want almost all of the time.

# --- Publishing -------------------------------------------------------------------------------------------
# `npm run publish` reads it
PUBLISH_KEY=

# --- Database (Studio only) -------------------------------------------------------------------------------
# Write token for the external save database.
#
# ⚠  This is a LIVE WRITE PATH TO PRODUCTION. There is no staging database, and it is not just the Save
#    button: a Studio session autosaves every 5 minutes and snapshots your plot when you leave, so a token
#    here overwrites your real slots without you pressing anything.
#
#    Leave it empty unless you are specifically testing writes, and clear it when you are done. Empty means
#    read-only: loads work, saves stay in the datastore and never leave your session.
WRITETOKEN=

# Where Studio looks for the database.
# Set this to the relay (below) if your connection cannot pull real saves. 
# Leave it empty for production build.
DB_BASEURL=

# --- Relay (scripts/dbrelay.js) ---------------------------------------------------------------------------
# Only `npm run dbrelay` reads these. You need the relay only if loading a slot in Studio fails with
# HttpError: NetFail or Timedout — see the README.
#
# The relay has TWO ENDS, and the settings below belong to opposite ones. RELAY_PORT is not a port ON
# ftrookie.com — nothing here ever produces an address like "https://ftrookie.com:1367".
#
#            the game talks to THIS end                    the relay talks out THIS end
#                        │                                              │
#                        ▼                                              ▼
#     Studio ──► http://localhost:1367/overengineered ──► [proxy] ──► https://ftrookie.com  (:443)
#                        ▲            ▲          ▲                      ▲
#                        │            │          │                      │
#                   (localhost)   RELAY_PORT   the path             RELAY_TARGET
#                                              the game asks for,
#                                              forwarded as-is
#
# So:
#   RELAY_PORT     where the relay LISTENS, on your machine. Nothing to do with the upstream.
#   RELAY_TARGET   where the relay CONNECTS OUT to. Its own scheme decides the upstream port
#                  (https -> 443, http -> 80). Origin only — no path: the path arrives with the request.
#   DB_BASEURL     what you point Studio at. This is the one that carries localhost, RELAY_PORT and the
#                  base path together, because it is a normal URL the game requests.
#
# Change RELAY_PORT and you must change DB_BASEURL to match, or Studio dials a port nobody is listening on.

# The proxy to tunnel through. Empty = go direct, which defeats the point of the relay.
RELAY_PROXY=

# The defaults are almost always right. Point RELAY_TARGET at a self-hosted database instead if you run one:
# https://github.com/anywaymachines/overengineered-database-selfhost
RELAY_TARGET=https://ftrookie.com
RELAY_PORT=1367
