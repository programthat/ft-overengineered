	ExtB2.Orientation  = Vector3.new(0, sunHDG + 180, 0)
	ExtSB1.Orientation = Vector3.new(0, sunHDG - 180, 0)
	ExtSB2.Orientation = Vector3.new(0, sunHDG + 90,  0)

	-- --------------------------------------------------------
	-- Beam9–12 mirror Beam1/2 (loop replaces 28 individual assignments)
	-- --------------------------------------------------------
	for i = 1, 4 do
		local src = extraBeamSrc[i]
		local dst = extraBeams[i]
		dst.Width0        = src.Width0
		dst.Width1        = src.Width1
		dst.Brightness    = src.Brightness
		dst.Color         = src.Color
		dst.Transparency  = src.Transparency
		dst.LightEmission = src.LightEmission
		dst.Enabled       = src.Enabled
	end

	-- --------------------------------------------------------
	-- Belt of Venus width (sunset inner beams already set above; set here for non-scatter path)
	-- --------------------------------------------------------
	local BeltOfVenusWidth = math.clamp(-0.4 * HorizonElevationSunsetDifference + 1, 1, 10)
	local ExtWidthSunset   = ExtinctionWidthEquation / 4
	local ExtSunsetBelt    = ExtWidthSunset * BeltOfVenusWidth
	-- These are only written here if the scatter block above didn't already set them
	-- (Scatter block runs when ExtinctionSunsetTransparencyEquation &lt; 1 AND enableScatter is true)
	-- The non-scatter or fully-transparent path still needs widths set:
	if not (ExtinctionSunsetTransparencyEquation &lt; 1 and enableScatter) then
		for _, b in ipairs(sunsetInnerBeams) do b.Width0 = ExtWidthSunset; b.Width1 = ExtWidthSunset end
		for _, b in ipairs(beltBeams)        do b.Width0 = ExtSunsetBelt;  b.Width1 = ExtSunsetBelt  end
	end

	-- --------------------------------------------------------
	-- Ground atmosphere
	-- --------------------------------------------------------
	if CustGroundAtmo.Value then
		BottomAtmosphere.Position = Vector3.new(
			camPosX,
			xOverSF - (x - (0.975794628099 * x - 9972.10330579)) - altOff,
			camPosZ
		)
		local gaTrans = CustGroundAtmoT.Value
		BottomAtmosphere.Transparency = ((1 - gaTrans) / (1 + (1.0001 ^ -(x - 150000))))
			+ ((1.01 - gaTrans) / (1 + (1.0005 ^ (x - 10000)))) + gaTrans
		BottomAtmosphereMesh.VertexColor = EarthMesh.VertexColor
	else
		BottomAtmosphere.Position        = Vector3.new(0, 0, 0)
		BottomAtmosphere.Transparency    = 1
		BottomAtmosphereMesh.VertexColor = EarthMesh.VertexColor
	end

	-- --------------------------------------------------------
	-- Earth apparent movement
	-- --------------------------------------------------------
	local EarthPosition  = Earth.CFrame.Position
	local EarthOrientation = Earth.CFrame - EarthPosition
	local scaleVal      = CustScale.Value
	local hrpVel        = HumanoidRootPart.Velocity
	local hrpY          = HumanoidRootPart.Position.Y
	local circumference = 2 * math.pi * (20925656.2 + hrpY * scaleVal) / 360
	local VelocityX = ((hrpVel.X / scaleVal) * dt) / circumference
	local VelocityZ = ((hrpVel.Z / scaleVal) * dt) / circumference
	local RotationSpeed      = CFrame.Angles(math.rad(-VelocityZ), 0, math.rad(VelocityX))
	local NewEarthRotation   = RotationSpeed * EarthOrientation
	local NewEarthOrientation = NewEarthRotation + EarthPosition

	if CustApRot.Value then
		Earth.CFrame = NewEarthOrientation
	else
		Earth.CFrame = EarthOrientation
	end

	if ClockTimeExists and CustApSunMove.Value then
		InitialTime = Workspace.ServerClockTime.Value % 24
	end

	if CustApSunMove.Value then
		SunOffsetX = SunOffsetX + VelocityX * 4
		SunOffsetZ = SunOffsetZ + (-VelocityZ)
		if CustApSunMoveEq.Value then
			Lighting:SetMinutesAfterMidnight(InitialTime * 60 + SunOffsetX)
		else
			Lighting:SetMinutesAfterMidnight(InitialTime * 60 + SunOffsetX)
			Lighting.GeographicLatitude = InitialGL + SunOffsetZ
		end
		local hrpPos = HumanoidRootPart.Position
		if hrpPos.X &gt;= -10000 and hrpPos.X &lt; 10000
			and hrpPos.Z &gt;= -10000
			and (hrpPos.Y + altOff) &lt; 1000 then
			SunOffsetX = 0
			SunOffsetZ = 0
			Earth.Orientation = CustInitOrientation.Value
		end
	end

	-- --------------------------------------------------------
	-- Atmosphere twilight darkness
	-- --------------------------------------------------------
	local ATDa = 1.42956638935406912395e-17
	local ATDb = 3.11869410895
	local ATDc = 5010.5925368
	local ATDd = -0.998839715953

	local ATDTimeCompensation
	local CT = Lighting.ClockTime
	if CT &gt;= 5.9 and CT &lt; 6.2 then
		ATDTimeCompensation = (CT - 5.9) / 0.3
	elseif CT &gt;= 4.8 and CT &lt; 5.1 then
		ATDTimeCompensation = -(CT - 5.1) / 0.3
	elseif CT &gt;= 6.2 and CT &lt; 17.8 then
		ATDTimeCompensation = 1
	elseif CT &gt;= 17.8 and CT &lt; 18.1 then
		ATDTimeCompensation = -(CT - 18.1) / 0.3
	elseif CT &gt;= 18.9 and CT &lt; 19.2 then
		ATDTimeCompensation = (CT - 18.9) / 0.3
	elseif CT &gt;= 19.2 or CT &lt; 4.8 then
		ATDTimeCompensation = 1
	else
		ATDTimeCompensation = 0
	end

	if x &gt;= 5060 and x &lt; 250251 and CustGroundAtmo.Value then
		BottomAtmosphereDarkness.Transparency = math.clamp(ATDa * (x^ATDb) + ATDc * (x^ATDd), 0, 1) + ATDTimeCompensation
	else
		BottomAtmosphereDarkness.Transparency = 1
	end

	-- --------------------------------------------------------
	-- Earth atmosphere color (special case for default Earth color)
	-- --------------------------------------------------------
	if CustAtmoColor.Value == Color3.fromRGB(115, 180, 255) then
		local groundAtmoFactor = math.clamp(1 - ((xOverSF) / 32808), 0, 1)
			* (math.clamp(HorizonElevationSunsetDifference, 0, 10) / 10)
		Atmosphere.Color = Color3.new(0, (95/255) * groundAtmoFactor, (148/255) * groundAtmoFactor)

		local sunsetFade15 = math.clamp(HorizonElevationSunsetDifference / H15, 0, 1)
		local altitudeFade = 1 - math.clamp(((xOverSF - 100000) / 20000), 0, 1)
		local fc = Lighting.FogColor
		Lighting.FogColor = Color3.new(
			fc.R * (1 + 0.0434782608695652  * sunsetFade15 * altitudeFade),
			fc.G * (1 + 0.2222222222222222  * sunsetFade15 * altitudeFade),
			fc.B * (1 + 0.4313725490196079  * sunsetFade15 * altitudeFade)
		)
	else
		Atmosphere.Color = Color3.new()
	end

	local atmosphericReflectionFactor = math.clamp(HorizonElevationSunsetDifference / 10, 0, 1)
	local reflColor = CustAtmoReflect.Value
	Lighting.Ambient = Color3.new(
		reflColor.R * atmosphericReflectionFactor,
		reflColor.G * atmosphericReflectionFactor,
		reflColor.B * atmosphericReflectionFactor
	)
end)</string>
