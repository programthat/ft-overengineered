-- ============================================================
-- Post-init: deep Customize path caches
-- ============================================================
local CustScale         = Cust.Scale
local CustAltOff        = Cust.AltitudeOffset
local CustAtmoColor     = Cust.AtmosphereColor
local CustAtmoSunset    = Cust.AtmosphereSunsetColor
local CustDistSurf      = Cust.DistantSurfaceColor
local CustAtmoTrans     = Cust.AtmosphereTransparency
local CustAtmoThick     = Cust.AtmosphereThickness
local CustPlanetTrans   = Cust.PlanetTransparency
local CustPlanetTex     = Cust.PlanetTexture
local CustPlanetTexNight= Cust.PlanetTextureNight
local CustSunsetScatter = Cust.EnableSunsetScattering
local CustBeltOfVenus   = Cust.BeltOfVenusColor
local CustAtmoExtColor  = Cust.AtmosphericExtinctionColor
local CustAtmoReflect   = CustAtmoColor.AtmosphereReflectionColor

local CustEnvLight      = Cust.EnableEnvironmentalLightingChanges
local CustEnvDayAmb     = CustEnvLight.OutdoorAmbientBrightnessDay
local CustEnvNightAmb   = CustEnvLight.OutdoorAmbientBrightnessNight
local CustEnvSunBright  = CustEnvLight.SunlightBrightness
local CustEnvNightBright= CustEnvLight.NightBrightness
local CustEnvDayColor   = CustEnvLight.DaytimeSunlightColor
local CustEnvSunrise    = CustEnvLight.SunriseSunlightColor

local CustSunCust       = Cust.EnableSun
local CustSunBright     = CustSunCust.SunBrightness
local CustSunDia        = CustSunCust.SunApparentDiameter
local CustSunTemp       = CustSunCust.SunTemp
local CustSunShine      = CustSunCust.SunshineTexture
local CustSunExtColor   = CustSunCust.SunAtmosphericExtinctionColor
local CustSunExtInter   = CustSunCust.SunAtmosphericExtinctionIntermediateColor
local CustSun3DExtColor = CustSunCust.ThreeDimensionalSunAtmosphericExtinctionColor

local CustApRot         = Cust.EnableApparentPlanetRotation
local CustApSunMove     = CustApRot["EnableApparentSunMovement (EXPERIMENTAL)"]
local CustApSunMoveEq   = CustApSunMove.EquatorialMovementOnly
local CustInitOrientation = CustApRot.InitialPlanetOrientation

local CustAirglowCust   = Cust.EnableAirglow
local CustAirglowTrans  = CustAirglowCust.AirglowTransparency
local CustAirglowColor  = CustAirglowCust.AirglowColor

local CustMoonCust      = Cust.EnableMoon
local CustMoonDia       = CustMoonCust.MoonApparentDiameter
local CustMoonTex       = CustMoonCust.MoonTexture

local CustGroundAtmo    = Cust.EnableGroundAtmosphere
local CustGroundAtmoT   = CustGroundAtmo.GroundAtmosphereTransparency

local CustExtinctAstro  = CustAtmoExtColor.AstronomicalTwilightAtmosphericExtinctionColor
local CustExtinctInner  = CustAtmoExtColor.InnerAtmosphericExtinctionColor
local CustExtinctNautInner = CustAtmoExtColor.NauticalInnerAtmosphericExtinctionColor
local CustExtinctSunside   = CustAtmoExtColor.SunsideAtmosphericExtinctionColor
local CustExtinctNaut      = CustAtmoExtColor.NauticalTwlightAtmosphericExtinctionColor

-- ============================================================
-- Post-init: Extinction beam group containers
-- ============================================================
local ExtB1  = Extinction.AtmosphericExtinction1
local ExtB2  = Extinction.AtmosphericExtinction2
local ExtSB1 = ExtinctionSunset.AtmosphericExtinction1
local ExtSB2 = ExtinctionSunset.AtmosphericExtinction2

-- Pre-built beam arrays for loop-based property setting
local extBeams   = { ExtB2.Beam1, ExtB2.Beam2, ExtB2.Beam3, ExtB2.Beam4,
	ExtB2.Beam5, ExtB2.Beam6, ExtB2.Beam7, ExtB2.Beam8 }
local extBeams14 = { ExtB2.Beam1, ExtB2.Beam2, ExtB2.Beam3, ExtB2.Beam4 }
local extBeams58 = { ExtB2.Beam5, ExtB2.Beam6, ExtB2.Beam7, ExtB2.Beam8 }

local extSBeams      = { ExtSB2.Beam1, ExtSB2.Beam2, ExtSB2.Beam3, ExtSB2.Beam4,
	ExtSB2.Beam5, ExtSB2.Beam6, ExtSB2.Beam7, ExtSB2.Beam8 }
local beltBeams      = { ExtSB2.Beam3, ExtSB2.Beam4, ExtSB2.Beam7, ExtSB2.Beam8 }
local sunsetInnerBeams = { ExtSB2.Beam1, ExtSB2.Beam2, ExtSB2.Beam5, ExtSB2.Beam6 }

-- Beam9–12 are copies of Beam1/2; store source→dest pairs
local extraBeamSrc = { ExtSB2.Beam1, ExtSB2.Beam2, ExtSB2.Beam1, ExtSB2.Beam2 }
local extraBeams   = { ExtSB2.Beam9, ExtSB2.Beam10, ExtSB2.Beam11, ExtSB2.Beam12 }

-- Pre-built attachment tables: {attachmentObject, yOffset}
-- All Extinction attachments use Vector3.new(EO, yOff + sunHDG, 0)
local ExtAtt = {
	{ ExtB2.Attachment2a,  90 }, { ExtB1.Attachment3a,   0 }, { ExtB2.Attachment4a, -90 },
	{ ExtB2.Attachment1b,  90 }, { ExtB1.Attachment2b,   0 }, { ExtB2.Attachment3b, -90 },
	{ ExtB1.Attachment1a, 180 }, { ExtB1.Attachment4b, 180 },
	{ ExtB2.Attachment6a,  90 }, { ExtB1.Attachment7a,   0 }, { ExtB2.Attachment8a, -90 },
	{ ExtB2.Attachment5b,  90 }, { ExtB1.Attachment6b,   0 }, { ExtB2.Attachment7b, -90 },
	{ ExtB1.Attachment5a, 180 }, { ExtB1.Attachment8b, 180 },
}
-- All ExtinctionSunset attachments use Vector3.new(81, yOff + sunHDG, 0)
local ExtSAtt = {
	{ ExtSB2.Attachment2a,    0 }, { ExtSB1.Attachment3a,  -90 }, { ExtSB2.Attachment4a, -180 },
	{ ExtSB2.Attachment1b,    0 }, { ExtSB1.Attachment2b,  -90 }, { ExtSB2.Attachment3b,  180 },
	{ ExtSB1.Attachment1a,   90 }, { ExtSB1.Attachment4b,   90 },
	{ ExtSB2.Attachment6a,    0 }, { ExtSB1.Attachment7a,  -90 }, { ExtSB2.Attachment8a, -180 },
	{ ExtSB2.Attachment5b,    0 }, { ExtSB1.Attachment6b,  -90 }, { ExtSB2.Attachment7b,  180 },
	{ ExtSB1.Attachment5a,   90 }, { ExtSB1.Attachment8b,   90 },
}

-- ============================================================
-- Server clock / initial time
-- ============================================================
if ClockTimeExists and CustApSunMove.Value then
	InitialTime = Workspace.ServerClockTime.Value % 24
else
	InitialTime = Lighting.ClockTime
end

-- ============================================================
-- Replacement Sun (SunRays can't pass through opaque Atmosphere parts)
-- ============================================================
local function onPlayerEntered(character)
	local SunTextureGui
	do
		for _, v in pairs(script.Parent:GetChildren()) do
			if v:IsA("ScreenGui") then
				SunTextureGui = v
				break
			end
		end
		if not SunTextureGui then
			SunTextureGui = Instance.new("ScreenGui", Players.LocalPlayer:FindFirstChildOfClass("PlayerGui"))
			SunTextureGui.DisplayOrder = -1
			SunTextureGui.Name = "Sun"
		end
	end

	local SunTexture = Instance.new("ImageLabel", SunTextureGui)
	SunTexture.Image                = CustSunShine.Value
	SunTexture.BackgroundTransparency = 1
	SunTexture.Size                 = UDim2.new(0, 1000, 0, 1000)
	SunTexture.AnchorPoint          = Vector2.new(0.5, 0.5)
	SunTexture.ZIndex               = 1

	local IsObstructed = false

	local SunTexture2 = Instance.new("ImageLabel", SunTextureGui)
	SunTexture2.Image                = "rbxassetid://5200654205"
	SunTexture2.BackgroundTransparency = 1
	SunTexture2.Size                 = UDim2.new(0, (2100/Camera.FieldOfView), 0, (2100/Camera.FieldOfView))
	SunTexture2.AnchorPoint          = Vector2.new(0.5, 0.5)
	SunTexture2.ZIndex               = 2

	local SunTexture3 = SunTexture:Clone()
	SunTexture3.Parent = SunTextureGui

	Earth.Orientation = CustInitOrientation.Value
	SunOffsetX = 0
	SunOffsetZ = 0

	Run:UnbindFromRenderStep("Sunshine")
	Run:BindToRenderStep("Sunshine", Enum.RenderPriority.Last.Value, function()

		if CustSunCust.Value then
			SunTextureGui.Enabled  = true
			Sky.SunTextureId       = "rbxasset://sky/sun.jpg"
		else
			SunTextureGui.Enabled  = false
			Sky.SunTextureId       = ""
		end

		-- Per-frame locals (Sunshine)
		local scaleFactor   = CustScale.Value ^ -1
		local altOff        = CustAltOff.Value
		local camCF         = Camera.CFrame
		local camPos        = camCF.Position
		local x             = (camPos.Y + altOff) * scaleFactor
		local altExp        = 2 ^ (-x / 500000)
		local sunBright     = CustSunBright.Value
		local SunDirectionV = Lighting:GetSunDirection()
		local sunPosition   = camCF.p + SunDirectionV * 999
		local screenPosition, isVisible = Camera:WorldToScreenPoint(sunPosition)
		local CamToSun      = Ray.new(camCF.p, SunDirectionV * 999)
		local CamToSunDir   = SunDirectionV * 999 - camCF.LookVector
		local ignore        = {}
		local SunElevation  = math.deg(math.atan(CamToSunDir.y / math.sqrt(CamToSunDir.x^2 + CamToSunDir.z^2)))
		local HorizonElevation = -math.deg(math.acos(20925656.2 / (20925656.2 + x)))
		local CamZoomDistance  = (Camera.Focus.Position - camPos).Magnitude
		local HorizonElevationSunsetDifference = SunElevation - HorizonElevation
		local ApparentDiameter  = CustSunDia.Value
		local SunExtR  = CustSunExtColor.Value.R * 255
		local SunExtG  = CustSunExtColor.Value.G * 255
		local SunExtB  = CustSunExtColor.Value.B * 255
		local SunExtIR = CustSunExtInter.Value.R * 255
		local SunExtIG = CustSunExtInter.Value.G * 255
		local SunExtIB = CustSunExtInter.Value.B * 255

		local SunsetFOVTransparencyScale = 1 - math.clamp(
			((Camera.FieldOfView - 5) / 5 + 1)
				* (HorizonElevationSunsetDifference ^ 3 / 10), 0, 1
		)
		local H1 = 6 * altExp

		if HorizonElevationSunsetDifference &lt;= 0 then
			HorizonElevationSunsetDifference10 = 0
		elseif HorizonElevationSunsetDifference &lt;= H1 then
			HorizonElevationSunsetDifference10 = HorizonElevationSunsetDifference
		else
			HorizonElevationSunsetDifference10 = H1
		end

		local HorizonElevationSunsetDifference10Ratio    = HorizonElevationSunsetDifference10 / H1
		local HorizonElevationSunsetDifference10Ratio3   = (math.clamp(HorizonElevationSunsetDifference10, 0, 2) * 3) / H1
		local HorizonElevationSunsetDifference10Ratio1_5 = (math.clamp(HorizonElevationSunsetDifference10, 0, 1) * 6) / H1

		table.insert(ignore, Atmosphere)
		if CamZoomDistance &lt;= 1.1 then
			table.insert(ignore, Character)
		else
			ignore[Character] = nil
		end

		local Obstructed = workspace:FindPartOnRayWithIgnoreList(CamToSun, ignore)
		SunTexture.Position  = UDim2.new(0, screenPosition.x, 0, screenPosition.y)
		SunTexture2.Position = UDim2.new(0, screenPosition.x, 0, screenPosition.y)
		SunTexture3.Position = UDim2.new(0, screenPosition.x, 0, screenPosition.y)
		IsObstructed = Obstructed ~= nil

		if isVisible then
			local AltitudeSunTransparencyFadeRate = math.clamp(-0.00000133333333333 * x + 0.75666666666666, 0.55, 0.75)
			SunTexture.ImageTransparency = 1 - math.clamp(
				((2 - (2.6111111111111 * AltitudeSunTransparencyFadeRate))
					* 30 * (HorizonElevationSunsetDifference10Ratio3 + 0.55
						- AltitudeSunTransparencyFadeRate - SunsetFOVTransparencyScale)),
				0, 1
			)
			SunTexture:TweenSize(
				UDim2.new(
					0, 100 + HorizonElevationSunsetDifference10Ratio * 900 * sunBright * (-((Camera.FieldOfView - 70) / 200) + 1),
					0, 100 + HorizonElevationSunsetDifference10Ratio * 900 * sunBright * (-((Camera.FieldOfView - 70) / 200) + 1)
				),
				Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true
			)
			SunTexture2.ImageTransparency = 1 - math.clamp(
				((2 - (2.6111111111111 * AltitudeSunTransparencyFadeRate))
					* 30 * (HorizonElevationSunsetDifference10Ratio1_5 + 0.55
						- AltitudeSunTransparencyFadeRate - SunsetFOVTransparencyScale)),
				0, 1
			)
			SunTexture2:TweenSize(
				UDim2.new(
					0, ((2.5 * Camera.ViewportSize.Y * ApparentDiameter / 31.983) / Camera.FieldOfView) * sunBright,
					0, ((2.5 * Camera.ViewportSize.Y * ApparentDiameter / 31.9)   / Camera.FieldOfView) * sunBright
				),
				Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true
			)

			local SunApparentDiameterRatio = ApparentDiameter / 31.983
			Sun3D.SunsetLight.Light.ImageTransparency = HorizonElevationSunsetDifference10Ratio
			Sun3D.Mesh.Scale = Vector3.new(
				12.25,
				10.5 + (1.75 * HorizonElevationSunsetDifference10Ratio),
				12.25
			) * SunApparentDiameterRatio

			if IsObstructed or SunElevation &lt;= HorizonElevation or HorizonElevation ~= HorizonElevation then
				SunTexture:TweenSize(UDim2.new(0, -5, 0, -5), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
				SunTexture2:TweenSize(UDim2.new(0, -5, 0, -5), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
			end

			SunTexture3.Size             = UDim2.new(0, SunTexture.Size.X.Offset / 2, 0, SunTexture.Size.Y.Offset / 2)
			SunTexture3.ImageColor3      = Color3.new(
				SunTexture.ImageColor3.R * 1.5,
				SunTexture.ImageColor3.G * 1.5,
				SunTexture.ImageColor3.B * 1.5
			)
			SunTexture3.Position         = SunTexture.Position
			SunTexture3.Rotation         = SunTexture.Rotation
			SunTexture3.ImageTransparency = SunTexture.ImageTransparency
		else
			SunTexture:TweenSize(UDim2.new(0, -5, 0, -5), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
			SunTexture2:TweenSize(UDim2.new(0, -5, 0, -5), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.1, true)
			SunTexture3.Size = SunTexture.Size
		end

		if SunTexture.Size.X.Offset &lt;= 0 then
			SunTexture.Visible  = false
			SunTexture2.Visible = false
			SunTexture3.Visible = false
		else
			SunTexture.Visible  = true
			SunTexture2.Visible = true
			SunTexture3.Visible = true
		end

		-- Sun Temperature
		local TempValue = math.clamp(CustSunTemp.Value, 2001, math.huge)
		if not CustSunsetScatter.Value then
			TempValue = CustSunTemp.Value
		end
		local Temp = (TempValue + 1095) / 100
		if TempValue &lt;= 0 then
			SunR, SunG, SunB = 255, 76, 0
		elseif TempValue &lt;= 1000 then
			SunR = 255
			SunG = 99.4708025861 * math.log(Temp) - 161.1195681661
			SunB = 0
		elseif TempValue &lt;= 2000 then
			SunR = 255
			SunG = 104.49216199393888 * math.log(Temp - 2) - 0.44596950469579133 * Temp - 155.25485562709179
			SunB = 0
		elseif TempValue &lt;= 6600 then
			SunR = 255
			SunG = 104.49216199393888 * math.log(Temp - 2) - 0.44596950469579133 * Temp - 155.25485562709179
			SunB = 115.67994401066147 * math.log(Temp - 10) + 0.8274096064007395 * Temp - 254.76935184120902
		elseif TempValue &lt;= 40000 then
			SunR = -40.25366309332127  * math.log(Temp - 55) + 0.114206453784165  * Temp + 351.97690566805693
			SunG = -28.0852963507957   * math.log(Temp - 50) + 0.07943456536662342 * Temp + 325.4494125711974
			SunB = 255
		else
			SunR, SunG, SunB = 162, 192, 255
		end

		local H2 = 3 * altExp
		if CustSunsetScatter.Value then
			local IntermediateColor = Color3.new(
				math.clamp(((((SunR - math.clamp(SunExtIR, 0, SunR - 1)) / (H2 * altExp))
					* (math.clamp(HorizonElevationSunsetDifference10, H2, H2 * 2) - H2)) + SunExtIR) / 255, 0, 1),
				math.clamp(((((SunG - math.clamp(SunExtIG, 0, SunG - 1)) / (H2 * altExp))
					* (math.clamp(HorizonElevationSunsetDifference10, H2, H2 * 2) - H2)) + SunExtIG) / 255, 0, 1),
				math.clamp(((((SunB - math.clamp(SunExtIB, 0, SunB - 1)) / (H2 * altExp))
					* (math.clamp(HorizonElevationSunsetDifference10, H2, H2 * 2) - H2)) + SunExtIB) / 255, 0, 1)
			)
			SunTexture.ImageColor3 = Color3.new(
				((((IntermediateColor.R * 255) - SunExtR) / (6 * altExp)) * HorizonElevationSunsetDifference10 + SunExtR) / 255,
				((((IntermediateColor.G * 255) - SunExtG) / (6 * altExp)) * HorizonElevationSunsetDifference10 + SunExtG) / 255,
				((((IntermediateColor.B * 255) - SunExtB) / (6 * altExp)) * HorizonElevationSunsetDifference10 + SunExtB) / 255
			)
		else
			SunTexture.ImageColor3 = Color3.new(
				(((SunR - SunExtR) / (6 * altExp)) * HorizonElevationSunsetDifference10 + SunExtR) / 255,
				(((SunG - SunExtG) / (6 * altExp)) * HorizonElevationSunsetDifference10 + SunExtG) / 255,
				(((SunB - SunExtB) / (6 * altExp)) * HorizonElevationSunsetDifference10 + SunExtB) / 255
			)
		end
		SunTexture.Rotation = -(screenPosition.x - Camera.ViewportSize.X / 2) / 100

		-- 3D Sunset
		if Lighting.ClockTime &lt; 12 then
			Sun3D.SunsetLight.ExtentsOffsetWorldSpace = Vector3.new(5, 0, 0)
		else
			Sun3D.SunsetLight.ExtentsOffsetWorldSpace = Vector3.new(-5, 0, 0)
		end

		local AboveHorizon = HorizonElevationSunsetDifference &gt; -2
		if x &gt; 5000 then
			AboveHorizon = HorizonElevationSunsetDifference &gt; 0
		elseif x &gt; 1000 then
			AboveHorizon = HorizonElevationSunsetDifference &gt; -0.5
		end

		if CustSunCust.Value then
			if AboveHorizon and HorizonElevationSunsetDifference &lt; H1 then
				Sun3D.Position    = camPos
				Sun3D.Mesh.Offset = Vector3.new(70000, 70000, 70000) * SunDirectionV
			else
				Sun3D.Position    = Vector3.new(0, -200000, 0)
				Sun3D.Mesh.Offset = Sun3D.Position
			end
			Sun3D.SunsetLight.StudsOffsetWorldSpace = Sun3D.Mesh.Offset
			Sun3D.SunsetLight.Brightness = math.clamp(400 - (x / 28), 40, 400)
			Sun3D.SunsetLight.Size       = UDim2.new(
				10000 * sunBright, 0,
				math.clamp((-x / 16) + 10000, 4000, 10000) * sunBright, 0
			)
			Sun3D.SunsetLight.Light.ImageColor3 = CustSun3DExtColor.Value
		else
			Sun3D.Position = camPos - Vector3.new(0, 100000, 0)
		end
	end)
end

repeat wait() until Character
onPlayerEntered(Character)
Players.LocalPlayer.CharacterAdded:Connect(onPlayerEntered)

-- ============================================================
-- Main render loop
-- ============================================================
Run.RenderStepped:Connect(function(dt)

	-- --------------------------------------------------------
	-- Per-frame cached locals
	-- --------------------------------------------------------
	local scaleFactor  = CustScale.Value ^ -1
	local altOff       = CustAltOff.Value
	local atmoThinness = CustAtmoTrans.Value
	local atmoHeight   = (CustAtmoThick.Value ^ -1) ^ 0.0625

	local camCF   = Camera.CFrame
	local camPos  = camCF.Position
	local camPosX = camPos.X
	local camPosY = camPos.Y
	local camPosZ = camPos.Z

	local x      = (camPosY + altOff) * scaleFactor
	local altExp = 2 ^ (-x / 500000)        -- used many times per frame
	local xOverSF = camPosY + altOff         -- = x / scaleFactor

	local H1  = 6  * altExp
	local H2  = 3  * altExp
	local H3  = 10 * altExp
	local H15 = 15 * altExp

	local ColorR = CustAtmoColor.Value.R * 255
	local ColorG = CustAtmoColor.Value.G * 255
	local ColorB = CustAtmoColor.Value.B * 255
	local ColorRSunset = CustAtmoSunset.Value.R * 255
	local ColorGSunset = CustAtmoSunset.Value.G * 255
	local ColorBSunset = CustAtmoSunset.Value.B * 255
	local ColorR2 = CustDistSurf.Value.R * 255
	local ColorG2 = CustDistSurf.Value.G * 255
	local ColorB2 = CustDistSurf.Value.B * 255

	local sunBright = CustSunBright.Value

	local SunDirectionV  = Lighting:GetSunDirection()
	local CamToSunDir    = SunDirectionV * 999 - camCF.LookVector
	local SunElevation   = math.deg(math.atan(CamToSunDir.y / math.sqrt(CamToSunDir.x^2 + CamToSunDir.z^2)))
	local HorizonElevation = -math.deg(math.acos(20925656.2 / (20925656.2 + math.clamp(x, 0, math.huge))))
	local HorizonElevationSunsetDifference = SunElevation - HorizonElevation
	local EarthTransparencyAltitudeMultiplier = 1 / (1 + 5 ^ (HorizonElevationSunsetDifference - 4))
	local LookAngle = math.deg(math.atan(camCF.LookVector.Y / math.sqrt(camCF.LookVector.X^2 + camCF.LookVector.Z^2)))
	local LookAngleHorizonDifference = LookAngle - HorizonElevation
	local EarthTerminatorX = 1.01
	local EarthTerminatorY = 1.2

	-- --------------------------------------------------------
	-- Atmosphere response to sunlight
	-- --------------------------------------------------------
	if HorizonElevationSunsetDifference &lt;= -18 then
		Atmosphere.Transparency = 1
		Sky.StarCount           = 3000
	elseif HorizonElevationSunsetDifference &lt;= -14 then
		Atmosphere.Transparency = -(HorizonElevationSunsetDifference + 14) / 4
		Sky.StarCount           = 3000
	elseif HorizonElevationSunsetDifference &lt;= 0 then
		Atmosphere.Transparency = 0
		Sky.StarCount           = 3000
	else
		Atmosphere.Transparency = 0
		Sky.StarCount           = 0
	end

	if HorizonElevationSunsetDifference &gt;= 0 and HorizonElevationSunsetDifference &lt; 3.75 then
		-- Pre-Sunrise/set
		local div = H3 / 2.666666666666
		local abs  = math.abs(HorizonElevationSunsetDifference)
		local ColorRResultant = math.clamp(-(ColorRSunset - ColorR) / div * abs + ColorRSunset, math.min(ColorR, ColorRSunset), math.max(ColorR, ColorRSunset))
		local ColorGResultant = math.clamp(-(ColorGSunset - ColorG) / div * abs + ColorGSunset, math.min(ColorG, ColorGSunset), math.max(ColorG, ColorGSunset))
		local ColorBResultant = math.clamp(-(ColorBSunset - ColorB) / div * abs + ColorBSunset, math.min(ColorB, ColorBSunset), math.min(ColorB, ColorBSunset))
		OutdoorAmbientBrightnessEquation = (((CustEnvDayAmb.Value - CustEnvNightAmb.Value) / 17.75) * (HorizonElevationSunsetDifference - 3.75) + CustEnvDayAmb.Value) / 255
		Lighting.FogColor = Color3.new(
			(ColorRResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255,
			(ColorGResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255,
			(ColorBResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255
		)
		Lighting.FogEnd          = (-100000 * (HorizonElevationSunsetDifference - 3.75) + 100000) * FogEndRatio * atmoThinness
		DistantSurface.Color     = Color3.new(ColorR2/255, ColorG2/255, ColorB2/255)
		sunBright                = CustEnvSunBright.Value
		AirglowLayer.Transparency = 1
		EarthTransparency        = ((CustPlanetTrans.Value - 0.011) / 3.75) * HorizonElevationSunsetDifference + 0.011
		EarthTexture.Color3      = Color3.new(1, 1, 1)

	elseif HorizonElevationSunsetDifference &gt;= -7 and HorizonElevationSunsetDifference &lt; 0 then
		-- Civil twilight
		local div  = H3 / 2.666666666666
		local abs  = math.abs(HorizonElevationSunsetDifference)
		local ColorRResultant = math.clamp(-(ColorRSunset - ColorR) / div * abs + ColorRSunset, math.min(ColorR, ColorRSunset), math.max(ColorR, ColorRSunset))
		local ColorGResultant = math.clamp(-(ColorGSunset - ColorG) / div * abs + ColorGSunset, math.min(ColorG, ColorGSunset), math.max(ColorG, ColorGSunset))
		local ColorBResultant = math.clamp(-(ColorBSunset - ColorB) / div * abs + ColorBSunset, math.min(ColorB, ColorBSunset), math.min(ColorB, ColorBSunset))
		OutdoorAmbientBrightnessEquation = (((CustEnvDayAmb.Value - CustEnvNightAmb.Value) / 17.75) * (HorizonElevationSunsetDifference - 3.75) + CustEnvDayAmb.Value) / 255
		Lighting.FogColor = Color3.new(
			(ColorRResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255,
			(ColorGResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255,
			(ColorBResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255
		)
		Lighting.FogEnd          = (-25000 * HorizonElevationSunsetDifference + 475000) * FogEndRatio * atmoThinness
		DistantSurface.Color     = Color3.new(0, 0, 0)
		sunBright                = CustEnvNightBright.Value
		AirglowLayer.Transparency = CustAirglowTrans.Value + AirglowTransparency
		EarthTransparency        = 0.011
		EarthTexture.Color3      = Color3.new(7, 7, 4.5)

	elseif HorizonElevationSunsetDifference &gt;= -14 and HorizonElevationSunsetDifference &lt; -7 then
		-- Nautical twilight
		local div  = H3 / 2.666666666666
		local abs  = math.abs(HorizonElevationSunsetDifference)
		local ColorRResultant = math.clamp(-(ColorRSunset - ColorR) / div * abs + ColorRSunset, math.min(ColorR, ColorRSunset), math.max(ColorR, ColorRSunset))
		local ColorGResultant = math.clamp(-(ColorGSunset - ColorG) / div * abs + ColorGSunset, math.min(ColorG, ColorGSunset), math.max(ColorG, ColorGSunset))
		local ColorBResultant = math.clamp(-(ColorBSunset - ColorB) / div * abs + ColorBSunset, math.min(ColorB, ColorBSunset), math.min(ColorB, ColorBSunset))
		OutdoorAmbientBrightnessEquation = (((CustEnvDayAmb.Value - CustEnvNightAmb.Value) / 17.75) * (HorizonElevationSunsetDifference - 3.75) + CustEnvDayAmb.Value) / 255
		Lighting.FogColor = Color3.new(
			(ColorRResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255,
			(ColorGResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255,
			(ColorBResultant / 17.75 * (HorizonElevationSunsetDifference + 14)) / 255
		)
		Lighting.FogEnd          = ((550000/7) * (HorizonElevationSunsetDifference + 7) + 650000) * FogEndRatio * atmoThinness
		DistantSurface.Color     = Color3.new(0, 0, 0)
		sunBright                = CustEnvNightBright.Value
		AirglowLayer.Transparency = CustAirglowTrans.Value + AirglowTransparency
		EarthTransparency        = 0.011
		EarthTexture.Color3      = Color3.new(7, 7, 4.5)

	elseif HorizonElevationSunsetDifference &lt; -14 then
		-- Night
		OutdoorAmbientBrightnessEquation = CustEnvNightAmb.Value / 255
		Lighting.FogColor    = Color3.new(0, 0, 0)
		Lighting.FogEnd      = 100000 * FogEndRatio * atmoThinness
		DistantSurface.Color = Color3.new(0, 0, 0)
		sunBright            = CustEnvNightBright.Value
		AirglowLayer.Transparency = CustAirglowTrans.Value + AirglowTransparency
		EarthTransparency    = 0.011
		EarthTexture.Color3  = Color3.new(7, 7, 4.5)

	elseif HorizonElevationSunsetDifference &gt;= 3.75 then
		-- Broad daylight
		OutdoorAmbientBrightnessEquation = CustEnvDayAmb.Value / 255
		Lighting.FogColor    = Color3.new(ColorR/255, ColorG/255, ColorB/255)
		Lighting.FogEnd      = 100000 * FogEndRatio * atmoThinness
		DistantSurface.Color = Color3.new(ColorR2/255, ColorG2/255, ColorB2/255)
		sunBright            = CustEnvSunBright.Value
		AirglowLayer.Transparency = 1
		EarthTransparency    = CustPlanetTrans.Value
		EarthTexture.Color3  = Color3.new(1, 1, 1)
	end

	if CustEnvLight.Value then
		local DayR = CustEnvDayColor.Value.R;  local DayG = CustEnvDayColor.Value.G;  local DayB = CustEnvDayColor.Value.B
		local SunR2 = CustEnvSunrise.Value.R;  local SunG2 = CustEnvSunrise.Value.G;  local SunB2 = CustEnvSunrise.Value.B
		local inv6altExp = 6 * altExp
		Lighting.OutdoorAmbient  = Color3.new(OutdoorAmbientBrightnessEquation, OutdoorAmbientBrightnessEquation, OutdoorAmbientBrightnessEquation)
		Lighting.Brightness      = sunBright
		Lighting.ColorShift_Top  = Color3.new(
			(((DayR - SunR2) / inv6altExp) * HorizonElevationSunsetDifference10) + SunR2,
			(((DayG - SunG2) / inv6altExp) * HorizonElevationSunsetDifference10) + SunG2,
			(((DayB - SunB2) / inv6altExp) * HorizonElevationSunsetDifference10) + SunB2
		)
	end

	-- --------------------------------------------------------
	-- Atmospheric extinction
	-- --------------------------------------------------------
	local AtmExtR = CustAtmoExtColor.Value.R * 255
	local AtmExtG = CustAtmoExtColor.Value.G * 255
	local AtmExtB = CustAtmoExtColor.Value.B * 255
	local HorizonElevationSunsetDifferenceAdjustmentEquation =
		-(((HorizonElevationSunsetDifference - 10) ^ 4) / 1000) + 10

	local enableScatter = CustSunsetScatter.Value

	if HorizonElevationSunsetDifference &lt;= H3 and HorizonElevationSunsetDifference &gt; 0 then
		LightEmissionEquation              = (1 / H3) * HorizonElevationSunsetDifference
		ExtinctionSunsetTransparencyEquation = (1 / H3 * HorizonElevationSunsetDifference)
		if enableScatter then
			ExtinctionTransparencyEquation = 0.8 / H3 * HorizonElevationSunsetDifferenceAdjustmentEquation
			ExtinctionColorEquation = Color3.fromRGB(
				((255 - AtmExtR) / (10 * altExp)) * HorizonElevationSunsetDifference + AtmExtR,
				((255 - AtmExtG) / (10 * altExp)) * HorizonElevationSunsetDifference + AtmExtG,
				((255 - AtmExtB) / (10 * altExp)) * HorizonElevationSunsetDifference + AtmExtB
			)
		else
			ExtinctionTransparencyEquation = 0.8
			ExtinctionColorEquation = Color3.fromRGB(255, 255, 255)
		end
	elseif HorizonElevationSunsetDifference &gt; H3 then
		LightEmissionEquation              = 1
		ExtinctionTransparencyEquation     = 0.8
		ExtinctionSunsetTransparencyEquation = 1
		ExtinctionColorEquation            = Color3.fromRGB(255, 255, 255)
	elseif HorizonElevationSunsetDifference &gt; -14 and HorizonElevationSunsetDifference &lt;= 0 then
		LightEmissionEquation              = 0
		ExtinctionSunsetTransparencyEquation = (1 / (1.2 * H3)) * math.abs(HorizonElevationSunsetDifference)
		if enableScatter then
			ExtinctionTransparencyEquation = -HorizonElevationSunsetDifference / 14
			local AstR = CustExtinctAstro.Value.R * 255
			local AstG = CustExtinctAstro.Value.G * 255
			local AstB = CustExtinctAstro.Value.B * 255
			ExtinctionColorEquation = Color3.fromRGB(
				((AstR - AtmExtR) / 14) * -HorizonElevationSunsetDifference + AtmExtR,
				((AstG - AtmExtG) / 14) * -HorizonElevationSunsetDifference + AtmExtG,
				((AstB - AtmExtB) / 14) * -HorizonElevationSunsetDifference + AtmExtB
			)
		else
			ExtinctionTransparencyEquation = 0.8
			ExtinctionColorEquation = Color3.fromRGB(255, 255, 255)
		end
	elseif HorizonElevationSunsetDifference &lt;= -14 then
		LightEmissionEquation              = 0
		ExtinctionTransparencyEquation     = 1
		ExtinctionSunsetTransparencyEquation = 1
		if enableScatter then
			ExtinctionColorEquation = Color3.fromRGB(AtmExtR, AtmExtG, AtmExtB)
		else
			ExtinctionTransparencyEquation = 0.8
			ExtinctionColorEquation = Color3.fromRGB(255, 255, 255)
		end
	end

	local ExtinctionIntensity = ((1 - 5) / 20000) * math.clamp(x - 20000, 0, 20000) + 5

	-- Use loops instead of 8 individual assignments
	local altCl       = math.clamp(x / 32808, 0, 1)
	local hesdClamp   = math.clamp(HorizonElevationSunsetDifference, -14, 0)
	local ExtTrans1 = NumberSequence.new(
		ExtinctionTransparencyEquation / (1.5 - 0.5 * altCl) * ((2/3) * (1 + (14 + hesdClamp) / 28))
	)
	local ExtTrans2 = NumberSequence.new(
		ExtinctionTransparencyEquation / (2 * (1 + hesdClamp / 28))
	)
	local ExtColorSeq = ColorSequence.new(ExtinctionColorEquation, ExtinctionTransparencyEquation)

	for i = 1, 4 do
		local b = extBeams14[i]
		b.Brightness    = ExtinctionIntensity
		b.LightEmission = LightEmissionEquation
		b.Transparency  = ExtTrans2
		b.Color         = ExtColorSeq
		b.Width0        = ExtinctionWidthEquation
		b.Width1        = ExtinctionWidthEquation
	end
	for i = 1, 4 do
		local b = extBeams58[i]
		b.Brightness    = ExtinctionIntensity
		b.LightEmission = LightEmissionEquation
		b.Transparency  = ExtTrans1
		b.Color         = ExtColorSeq
		b.Width0        = ExtinctionWidthEquation
		b.Width1        = ExtinctionWidthEquation
	end

	-- --------------------------------------------------------
	-- Sunset scattering beams
	-- --------------------------------------------------------
	if ExtinctionSunsetTransparencyEquation &lt; 1 and enableScatter then
		local ExtinctionSunsetBrightness = math.clamp(3 * HorizonElevationSunsetDifference + 10, 10, 40)
		local ExtWidthS  = ExtinctionWidthEquation / 4
		local BeltOfVenusWidth = math.clamp(-0.4 * HorizonElevationSunsetDifference + 1, 1, 10)
		local ExtSunsetBelt = ExtWidthS * BeltOfVenusWidth

		local esd10 = ExtinctionSunsetTransparencyEquation
		local ExtTransSS1 = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 1),
			NumberSequenceKeypoint.new(math.clamp(((HorizonElevationSunsetDifference - 10) / 30) + 1, 0.3, 1), esd10 + 0.1),
			NumberSequenceKeypoint.new(1, esd10),
		})
		local ExtTransSS2 = NumberSequence.new({
			NumberSequenceKeypoint.new(0, esd10),
			NumberSequenceKeypoint.new(math.clamp(-(HorizonElevationSunsetDifference - 10) / 30, 0.3, 1), esd10 + 0.1),
			NumberSequenceKeypoint.new(1, 1),
		})
		local bovExtra = math.clamp(-(HorizonElevationSunsetDifference + 6.6) / 2.7, 0, 1)
		local ExtTransSS1BoV = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 1),
			NumberSequenceKeypoint.new(math.clamp(((HorizonElevationSunsetDifference - 10) / 30) + 1, 0.3, 1), esd10 + 0.1),
			NumberSequenceKeypoint.new(1, esd10 + bovExtra),
		})
		local ExtTransSS2BoV = NumberSequence.new({
			NumberSequenceKeypoint.new(0, esd10 + bovExtra),
			NumberSequenceKeypoint.new(math.clamp(-(HorizonElevationSunsetDifference - 10) / 30, 0.3, 1), esd10 + 0.1 + bovExtra),
			NumberSequenceKeypoint.new(1, 1),
		})

		-- Transparency: Beams 1,5 = SS1; 2,6 = SS2; 3,7 = SS1BoV; 4,8 = SS2BoV
		ExtSB2.Beam1.Transparency = ExtTransSS1;  ExtSB2.Beam5.Transparency = ExtTransSS1
		ExtSB2.Beam2.Transparency = ExtTransSS2;  ExtSB2.Beam6.Transparency = ExtTransSS2
		ExtSB2.Beam3.Transparency = ExtTransSS1BoV; ExtSB2.Beam7.Transparency = ExtTransSS1BoV
		ExtSB2.Beam4.Transparency = ExtTransSS2BoV; ExtSB2.Beam8.Transparency = ExtTransSS2BoV

		local BeltOfVenusEmission = math.clamp(0.4 * HorizonElevationSunsetDifference + 1, 0, 1)
		local beltColor = ColorSequence.new(CustBeltOfVenus.Value)
		for _, b in ipairs(beltBeams) do
			b.Brightness    = ExtinctionSunsetBrightness
			b.Color         = beltColor
			b.LightEmission = BeltOfVenusEmission
			b.LightInfluence = BeltOfVenusEmission
			b.Width0        = ExtSunsetBelt
			b.Width1        = ExtSunsetBelt
		end

		-- Inner / sunside extinction colors
		local InnerAtmosphericExtinctionColor = CustExtinctInner.Value
		local SunsideColor = CustExtinctSunside.Value
		local hesdAbs = math.abs(HorizonElevationSunsetDifference)

		local InnerExtinctionSunsetColor = Color3.fromRGB(
			((CustAtmoExtColor.Value.R * 255 - SunsideColor.R * 255) / H3) * hesdAbs + SunsideColor.R * 255,
			((CustAtmoExtColor.Value.G * 255 - SunsideColor.G * 255) / H3) * hesdAbs + SunsideColor.G * 255,
			((CustAtmoExtColor.Value.B * 255 - SunsideColor.B * 255) / H3) * hesdAbs + SunsideColor.B * 255
		)
		if HorizonElevationSunsetDifference &lt; 0 then
			local NautColor = CustExtinctNaut.Value
			local NautInner = CustExtinctNautInner.Value
			InnerExtinctionSunsetColor = Color3.fromRGB(
				((NautColor.R * 255 - SunsideColor.R * 255) / H3) * hesdAbs + SunsideColor.R * 255,
				((NautColor.G * 255 - SunsideColor.G * 255) / H3) * hesdAbs + SunsideColor.G * 255,
				((NautColor.B * 255 - SunsideColor.B * 255) / H3) * hesdAbs + SunsideColor.B * 255
			)
