+-- Classic-runtime support: roblox-ts output that emits `local TS = require(...RuntimeLib)` and
+-- `game:GetService("ReplicatedStorage")`-absolute imports (anywaymachines/roblox-ts-awm), alongside
+-- Lunit's own `_G[script]` convention. Provides `game` + the Roblox datatype globals such modules assume.
+local CLASSIC_ROOTS = {
+	rbxts_include = "node_modules/roblox-ts/include",
+	TS = "out/shared",
+	engine = "out/engine/shared",
+}
+local classicTS -- assigned once buildTS exists
+local fakeRunService = {
+	IsStudio = function() return false end,
+	IsRunning = function() return false end,
+	IsClient = function() return false end,
+}
+local fakeRS = setmetatable({}, {
+	__index = function(_, key)
+		if key == "WaitForChild" or key == "FindFirstChild" then
+			return function(_, name)
+				return makeScript(CLASSIC_ROOTS[name] or error("rbxts shim: unmapped RS child " .. tostring(name)))
+			end
+		end
+		return makeScript(CLASSIC_ROOTS[key] or error("rbxts shim: unmapped RS child " .. tostring(key)))
+	end,
+})
+local fakeGame = {
+	IsLoaded = function() return true end,
+	GetService = function(_, n)
+		if n == "RunService" then return fakeRunService end
+		if n == "ReplicatedStorage" then return fakeRS end
+		error("rbxts shim: unshimmed service " .. tostring(n))
+	end,
+}
+local function classicRequire(arg)
+	if type(arg) == "string" then
+		return luneRequire(arg)
+	end
+	if type(arg) == "table" and arg.__path and string.match(arg.__path, "RuntimeLib$") then
+		return classicTS
+	end
+	error("rbxts shim: unexpected require")
+end
+local function typeIs(v, t)
+	local tn = typeof(v)
+	if tn == t then return true end
+	if tn == "Instance" then
+		local ok, r = pcall(function() return v:IsA(t) end)
+		return ok and r or false
+	end
+	return false
+end
+_G.game, _G.require, _G.typeIs = fakeGame, classicRequire, typeIs
